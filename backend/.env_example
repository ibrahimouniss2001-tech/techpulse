# =====================================================
#  BACKEND — Variables de entorno
#  Copia este archivo como .env y rellena los valores
# =====================================================

# ── IA ────────────────────────────────────────────────
# Clave de Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# ── Base de datos ─────────────────────────────────────
# En LOCAL no hace falta (usa SQLite automáticamente).
# En RAILWAY: pega aquí la URL que te da Railway al crear el PostgreSQL.
# DATABASE_URL=postgresql://usuario:password@host:5432/railway

# ── Seguridad ─────────────────────────────────────────
# Clave para proteger los endpoints de escritura.
# Ponla también en Railway como variable de entorno.
API_KEY_SECRETA=cambia_esto_por_algo_seguro_largo

# ── Vercel Deploy Hook ────────────────────────────────
# Vercel Dashboard → tu proyecto → Settings → Git → Deploy Hooks
# Crea uno con nombre "backend-trigger" y pega la URL aquí.
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...

# ── Imágenes (Unsplash) ───────────────────────────────
# Registro gratuito en https://unsplash.com/developers
# Crea una app y copia el Access Key.
UNSPLASH_ACCESS_KEY=tu_access_key

# ── Watcher (solo en tu ordenador local) ─────────────
# En local apunta a localhost. Cuando el backend esté en Railway,
# cambia esto a tu URL de Railway: https://tu-app.railway.app
API_URL=http://localhost:8000
