# TechPulse — Variables de entorno
# Copia este archivo como .env.local y rellena los valores

# ==== SITE ====
NEXT_PUBLIC_SITE_URL=https://www.techpulse.dev

# ==== GOOGLE ADSENSE ====
# Reemplaza con tu Publisher ID real
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# ==== NEWSLETTER ====
# Opción A: Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER=us1
MAILCHIMP_LIST_ID=

# Opción B: ConvertKit
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Opción C: Resend
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# ==== ANALYTICS ====
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==== SEO ====
NEXT_PUBLIC_GOOGLE_VERIFICATION=GOOGLE_VERIFICATION_TOKEN
